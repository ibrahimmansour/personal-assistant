{
  "name": "personal-assistant-dashboard",
  "version": "0.3.3",
  "private": false,
  "description": "A widget-based personal dashboard with email, calendar, tasks, GitHub PRs, Jira, terminal, and more",
  "bin": {
    "personal-assistant-dashboard": "./bin/cli.js"
  },
  "files": [
    "bin/cli.js"
  ],
  "scripts": {
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 node server/dev-launcher.mjs",
    "dev:next": "NODE_TLS_REJECT_UNAUTHORIZED=0 next dev --port 4444",
    "dev:pty": "node server/pty-server.mjs",
    "dev:relay": "node server/claude-relay/relay.mjs",
    "build": "next build",
    "start": "NODE_TLS_REJECT_UNAUTHORIZED=0 node server/pty-server.mjs & node server/claude-relay/relay.mjs & NODE_TLS_REJECT_UNAUTHORIZED=0 next start --port 4444",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true",
    "lint": "eslint",
    "build:binary": "node scripts/build-binary.mjs",
    "build:binary:all": "node scripts/build-binary.mjs --all"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.146",
    "@base-ui/react": "^1.3.0",
    "@monaco-editor/react": "^4.7.0",
    "@tiptap/extension-color": "^3.22.2",
    "@tiptap/extension-highlight": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/extension-task-item": "^3.22.2",
    "@tiptap/extension-task-list": "^3.22.2",
    "@tiptap/extension-text-align": "^3.22.2",
    "@tiptap/extension-text-style": "^3.22.2",
    "@tiptap/extension-underline": "^3.22.2",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@types/react-grid-layout": "^1.3.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "node-pty": "^1.1.0",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-grid-layout": "^2.2.3",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.1.2",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
